<%= render 'common/search' %>
<%= flash_notice %>

<table class="banks table table-striped table-hover my-4">
  <thead>
    <tr>
      <th rowspan="2" class="text-center align-middle"><%= Bank.human_attribute_name :code %></th>
      <th rowspan="2" class="align-middle"><%= Bank.human_attribute_name :name %></th>
      <th rowspan="2" class="text-center align-middle"><%= Bank.human_attribute_name :enterprise_number %></th>
      <th rowspan="2" class="text-center align-middle"><%= Bank.human_attribute_name :disabled %></th>
      <th colspan="3" class="text-center" style="width: 20%;">振込手数料（3万円未満）</th>
      <th colspan="3" class="text-center" style="width: 20%;">振込手数料（3万円以上）</th>
      <th rowspan="2" class="text-center align-middle" style="width: 10%;"></th>
    </tr>
    <tr>
      <th class="text-center">同じ支店</th>
      <th class="text-center">他の支店</th>
      <th class="text-center">他の機関</th>
      <th class="text-center">同じ支店</th>
      <th class="text-center">他の支店</th>
      <th class="text-center">他の機関</th>
    </tr>
  </thead>
  <tbody>
    <% @banks.each do |bank| %>
      <tr>
        <td class="text-center"><%= bank.code %></td>
        <td><%= link_to bank.name, mm_bank_path(bank), class: 'show', remote: true %></td>
        <td class="text-center"><%= bank.enterprise_number %></td>
        <td class="text-center"><%= HyaccConst::DISABLED_TYPES[bank.disabled] %></td>
        <td class="text-end"><%= bank.lt_30k_same_office %></td>
        <td class="text-end"><%= bank.lt_30k_other_office %></td>
        <td class="text-end"><%= bank.lt_30k_other_bank %></td>
        <td class="text-end"><%= bank.ge_30k_same_office %></td>
        <td class="text-end"><%= bank.ge_30k_other_office %></td>
        <td class="text-end"><%= bank.ge_30k_other_bank %></td>
        <td class="text-center">
          <%= link_to '編集', edit_mm_bank_path(bank), remote: true, class: 'btn btn-sm btn-light' %>
          <% if bank.disabled? %>
            <%= link_to '削除', mm_bank_path(bank), method: :delete, class: 'btn btn-sm btn-danger', data: {confirm: "#{bank.name} を削除します。よろしいですか？"} %>
          <% else %>
            <%= link_to '無効', disable_mm_bank_path(bank), method: :post, class: 'btn btn-sm btn-warning', data: {confirm: "#{bank.name} の状態を無効にします。よろしいですか？"} %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= will_paginate @banks %>
<%= link_to '追加', new_mm_bank_path, class: 'add btn btn-light', remote: true %>
