<%= fields_for "employee[branch_employees_attributes]", be, index: index do |f| %>
  <tr>
    <td>
      <%= f.hidden_field :id %>
      <%= f.select :branch_id, to_options(current_company.branches), {}, { class: 'form-control form-control-sm' } %>
    </td>
    <td class="text-center"><%= f.check_box :default_branch, class: 'form-check-input' %></td>
    <td class="text-center"><%= f.check_box :deleted, class: 'form-check-input' %></td>
  </tr>
<% end %>
