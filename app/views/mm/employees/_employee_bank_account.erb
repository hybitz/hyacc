<script>
  $(document).ready(function() {
    $('#employee_employee_bank_account_attributes_bank_id').change(function() {
      bank_accounts.update_bank_offices(this, '#employee_employee_bank_account_attributes_bank_office_id');
    });
  });
</script>
<%= fields_for "employee[employee_bank_account_attributes]", @e.employee_bank_account do |f| %>
  <%= f.hidden_field :id %>
  <tr>
    <th>金融機関名称</th>
    <td>
      <%= f.collection_select :bank_id, current_company.banks, :id, :name, {}, { href: bank_offices_path, class: 'form-control form-control-sm w-auto d-inline-block' } %>
    </td>
  </tr>
  <tr>
    <th>支店名称</th>
    <td>
      <%= f.collection_select :bank_office_id, f.object.bank.bank_offices, :id, :name, {}, { class: 'form-control form-control-sm w-auto d-inline-block' } %>
    </td>
  </tr>
  <tr>
    <th>口座番号</th>
    <td><%= f.text_field :code, class: 'form-control form-control-sm w-auto d-inline-block' %></td>
  </tr>
<% end %>
