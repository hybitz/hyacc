<%= fields_for @e do |f| %>
  <table class="table">
    <tr>
      <th><%= f.label :employment_date %></th>
      <td><%= f.date_select :employment_date %></td>
    </tr>
    <tr>
      <th><%= f.label :retirement_date %></th>
      <td><%= f.date_select :retirement_date, include_blank:true %></td>
    </tr>
    <tr>
      <th class="nowrap"><%= f.label :executive %></th>
      <td><label><%= f.check_box :executive %> <%= Employee.human_attribute_name :executive_true %></label></td>
    </tr>
    <tr>
      <th><%= f.label :position %></th>
      <td><%= f.text_field :position %></td>
    </tr>
    <tr>
      <th><%= f.label :full_time %></th>
      <td>
        <%= f.select :full_time, [['常勤', 'true'], ['非常勤', 'false']], { include_blank: true } %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :duty_description %></th>
      <td><%= f.text_field :duty_description %></td>
    </tr>
    <tr>
      <th><%= f.label :representative_or_family_type %></th>
      <td>
        <%= f.select :representative_or_family_type, representative_or_family_types, { include_blank: true } %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :relationship_to_representative %></th>
      <td><%= f.text_field :relationship_to_representative %></td>
    </tr>
  </table>
<% end %>
