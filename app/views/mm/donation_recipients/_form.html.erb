<%= form_with model: [:mm, @donation_recipient], data: { remote: true } do |f| %>
  <%= flash_notice %>

  <table class="table table-sm mb-0" style="min-width: 40em;">
    <% kind_locked = @donation_recipient.persisted? && @donation_recipient.journal_details.exists? %>
    <tr>
      <th style="width: 10em;"><%= f.label :kind %></th>
      <td>
        <%= f.select :kind, donation_recipient_kind_options, {}, class: 'form-control form-control-sm donation-recipient-kind', disabled: kind_locked, data: { kind: @donation_recipient.kind } %>
        <% if kind_locked %>
          <span class="text-muted small ms-2">
            （振替伝票に紐づいているため変更できません）
          </span>
        <% end %>
      </td>
    </tr>
    <tr>
      <th style="width: 10em;"><%= f.label :name %></th>
      <td><%= f.text_field :name, size: 30, class: 'form-control form-control-sm' %></td>
    </tr>
    <% # 指定(100): 告示番号・使途 %>
    <tr class="donation-recipient-fields kind-100" style="<%= 'display:none' unless @donation_recipient.kind == HyaccConst::SUB_ACCOUNT_CODE_DONATION_DESIGNATED %>">
      <th style="width: 10em;"><%= f.label :announcement_number %></th>
      <td><%= f.text_field :announcement_number, size: 20, class: 'form-control form-control-sm' %></td>
    </tr>
    <tr class="donation-recipient-fields kind-100" style="<%= 'display:none' unless @donation_recipient.kind == HyaccConst::SUB_ACCOUNT_CODE_DONATION_DESIGNATED %>">
      <th style="width: 10em;"><%= f.label :purpose %></th>
      <td><%= f.text_field :purpose, size: 30, class: 'form-control form-control-sm' %></td>
    </tr>
    <% # 特定公益増進(300): 所在地・使途又は名称。認定外(600): 所在地・特定公益信託の名称（所在地は共通のため1フィールド） %>
    <tr class="donation-recipient-fields kind-300 kind-600" style="<%= 'display:none' unless (HyaccConst::DONATION_RECIPIENT_SUB_ACCOUNT_CODES - [HyaccConst::SUB_ACCOUNT_CODE_DONATION_DESIGNATED]).include?(@donation_recipient.kind) %>">
      <th style="width: 10em;"><%= f.label :address %></th>
      <td><%= f.text_field :address, size: 40, class: 'form-control form-control-sm' %></td>
    </tr>
    <tr class="donation-recipient-fields kind-300" style="<%= 'display:none' unless @donation_recipient.kind == HyaccConst::SUB_ACCOUNT_CODE_DONATION_PUBLIC_INTEREST %>">
      <th style="width: 10em;"><%= f.label :purpose_or_name %></th>
      <td><%= f.text_field :purpose_or_name, size: 30, class: 'form-control form-control-sm' %></td>
    </tr>
    <% # 認定外(600): 特定公益信託の名称 %>
    <tr class="donation-recipient-fields kind-600" style="<%= 'display:none' unless @donation_recipient.kind == HyaccConst::SUB_ACCOUNT_CODE_DONATION_NON_CERTIFIED_TRUST %>">
      <th style="width: 10em;"><%= f.label :trust_name %></th>
      <td><%= f.text_field :trust_name, size: 30, class: 'form-control form-control-sm' %></td>
    </tr>
  </table>
<% end %>

<script>
(function() {
  var kindSelect = document.querySelector('.donation-recipient-kind');
  if (!kindSelect) return;
  function toggleRows() {
    var kind = kindSelect.value;
    document.querySelectorAll('.donation-recipient-fields').forEach(function(tr) {
      tr.style.display = tr.classList.contains('kind-' + kind) ? '' : 'none';
    });
  }
  kindSelect.addEventListener('change', toggleRows);
})();
</script>
