var options = {
  title: '<%= title + '　参照' %>',
  buttons: [
    {
      text: '編集',
      class: 'btn btn-light',
      click: function() {
        hyacc.current_dialog().close();
        $.get('<%= edit_mm_branch_path(@branch) %>');
      }
    },
    <% unless @branch.head_office? %>
    {
      text: '削除',
      class: 'btn btn-light',
      click: function() {
        if (confirm('削除します。よろしいですか？')) {
          $.post('<%= mm_branch_path(@branch) %>', {
            authenticity_token: '<%= form_authenticity_token %>',
            _method: 'delete'
          });
        }
      }
    },
    <% end %>
    {
      text: '子部門追加',
      class: 'btn btn-light',
      click: function() {
        hyacc.current_dialog().close();
        $.get('<%= new_mm_branch_path(parent_id: @branch.id) %>');
      }
    }
  ]
};

hyacc.current_dialog(options).show('<%=j render 'show' %>');
