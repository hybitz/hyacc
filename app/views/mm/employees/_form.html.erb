<%= form_with model: [:mm, @e], data: {remote: true} do |f| %>
  <%= flash_notice %>

  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <table class="table table-sm mb-0">
          <tr>
            <th class="nowrap"><%= f.object.class.human_attribute_name(:last_name) %><%= f.object.class.human_attribute_name(:first_name) %></th>
            <td>
              <div class="d-flex flex-nowrap gap-0 align-items-stretch">
                <div class="flex-grow-1 min-w-0"><%= f.text_field :last_name, class: 'form-control' %></div>
                <div class="flex-grow-1 min-w-0"><%= f.text_field :first_name, class: 'form-control' %></div>
              </div>
            </td>
          </tr>
          <tr>
            <th><%= f.label :name_kana %></th>
            <td>
              <div class="d-flex flex-nowrap gap-0 align-items-stretch">
                <div class="flex-grow-1 min-w-0"><%= f.text_field :last_name_kana, class: 'form-control' %></div>
                <div class="flex-grow-1 min-w-0"><%= f.text_field :first_name_kana, class: 'form-control' %></div>
              </div>
            </td>
          </tr>
          <tr>
            <th><%= f.label :sex %></th>
            <td><%= f.select :sex, sex_types, {}, class: 'form-control form-control-sm', style: 'width: 4em;' %></td>
          </tr>
          <tr>
            <th><%= f.label :birth %></th>
            <td>
              <div class="d-flex flex-nowrap gap-1 align-items-center">
                <%= f.date_select :birth,
                      { start_year: Time.now.year - 65, end_year: Time.now.year - 18, include_blank: true },
                      { class: 'form-control form-control-sm w-auto', style: 'width: auto; display: inline-block; vertical-align: middle;' } %>
              </div>
            </td>
          </tr>
          <tr>
            <th><%= f.label :zip_code %></th>
            <td><%= f.nostalgic_text_field :zip_code, class: 'zip_code' %></td>
          </tr>
          <tr>
            <th><%= f.label :address %></th>
            <td><%= f.nostalgic_text_field :address, class: 'address' %></td>
          </tr>
          <tr>
            <th><%= f.label :my_number %></th>
            <td><%= f.text_field :my_number, class: 'form-control form-control-sm', style: 'width: 10em; max-width: 100%;' %></td>
          </tr>
          <tr>
            <th><%= f.label :social_insurance_reference_number %></th>
            <td><%= f.text_field :social_insurance_reference_number, class: 'form-control form-control-sm', style: 'width: 4em; max-width: 100%;' %></td>
          </tr>
          <tr>
            <th><%= f.label :num_of_dependent %></th>
            <td><%= f.nostalgic_text_field :num_of_dependent %></td>
          </tr>
          <%= render 'employee_bank_account' %>
        </table>
      </div>
      <div class="col-md-4">
        <%= render 'evaluation' %>
        <%= render 'branch_employees', e: @e %>
      </div>
    </div>
  </div>
<% end %>
