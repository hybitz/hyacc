<script>
  $(document).ready(function() {
    hyacc.init_datepicker();
  });
</script>
<%= form_with model: [:mm, @skill], data: {remote: true} do |f| %>
  <%= flash_notice %>
  <% if @skill.new_record? %>
    <%= f.hidden_field :employee_id %>
    <%= f.hidden_field :qualification_id %>
  <% end %>

  <table class="table table-sm mb-0">
    <tr>
      <th><%= f.label :qualification_id %></th>
      <td>
        <%= f.object.qualification.name %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :qualified_on %></th>
      <td><%= f.text_field :qualified_on, class: 'form-control form-control-sm datepicker d-inline-block', style: 'width: 8em; max-width: 100%;' %></td>
    </tr>
  </table>
<% end %>
