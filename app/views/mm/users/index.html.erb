<div class="m-2 col-md-8">
  <%= flash_notice %>

  <table class="users table table-striped table-hover">
    <thead>
      <tr>
        <th class="text-center"><%= User.human_attribute_name :login_id %></th>
        <th>氏名</th>
        <% if current_user.admin? %>
          <th class="text-center"><%= User.human_attribute_name :admin %></th>
        <% end %>
        <th class="text-center">状態</th>
        <th class="text-center"></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td class="text-center"><%= user.login_id %></td>
          <td><%= link_to user.employee.fullname, {action: 'show', id: user.id}, class: 'show', remote: true %></td>
          <% if current_user.admin? %>
            <td class="text-center text-nowrap">
              <% if user.loginable? %>
                <% if user.admin? %>
                  あり
                  <%= link_to '解除', revoke_admin_mm_user_path(user), data: {confirm: '管理権限を解除します。よろしいですか？'}, method: :post, class: 'btn btn-sm btn-light' %>
                <% else %>
                  なし
                  <%= link_to '付与', grant_admin_mm_user_path(user), data: {confirm: '管理権限を付与します。よろしいですか？'}, method: :post, class: 'btn btn-sm btn-light' %>
                <% end %>
              <% else %>
                -
              <% end %>
            </td>
          <% end %>
          <td class="text-center"><%= HyaccConst::DELETED_TYPES[user.deleted] %></td>
          <td class="text-center text-nowrap">
            <%= link_to '編集', {action: 'edit', id: user.id}, remote: true, class: 'btn btn-sm btn-light' %>
            <%= link_to '削除', {action: 'destroy', id: user}, data: {confirm: '削除します。よろしいですか？'}, method: :delete, class: 'btn btn-sm btn-light' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= will_paginate @users %>
  <%= link_to '追加', {action: 'new'}, class: 'add btn btn-light', remote: true %>
</div>
