<%= form_with model: [:mm, @bank], data: {remote: true} do |f| %>
  <%= flash_notice %>

  <table class="table table-sm mb-0">
    <tr>
      <th><%= f.label :code %></th>
      <td>
        <% if @bank.new_record? %>
          <%= f.text_field :code, class: 'form-control form-control-sm', style: 'width: 6em; max-width: 100%;' %>
        <% else %>
          <%= @bank.code %>
        <% end %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :name %></th>
      <td class="text-nowrap"><%= f.nostalgic_text_field :name %></td>
    </tr>
    <tr>
      <th><%= f.label :enterprise_number %></th>
      <td><%= f.text_field :enterprise_number, class: 'form-control form-control-sm', style: 'width: 15em; max-width: 100%;' %></td>
    </tr>
  </table>

  <table class="table table-sm mt-3 mb-0">
    <thead>
      <tr>
        <th colspan="3" class="text-center">振込手数料（3万円未満）</th>
        <th colspan="3" class="text-center">振込手数料（3万円以上）</th>
      </tr>
      <tr>
        <th class="text-center">同じ支店</th>
        <th class="text-center">他の支店</th>
        <th class="text-center">他の機関</th>
        <th class="text-center">同じ支店</th>
        <th class="text-center">他の支店</th>
        <th class="text-center">他の機関</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <% %w{
          lt_30k_same_office
          lt_30k_other_office
          lt_30k_other_bank
          ge_30k_same_office
          ge_30k_other_office
          ge_30k_other_bank
        }.each do |column| %>
          <td class="text-center"><%= f.text_field column, class: 'form-control form-control-sm text-end d-inline-block', style: 'width: 6em;' %></td>
        <% end %>
      </tr>
    </tbody>
  </table>

  <%= render 'bank_offices_fields', bank_offices: @bank.bank_offices %>
<% end %>
